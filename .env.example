# Aria Environment Variables
# Copy this to .env.local and fill in values for local development.

# API key for securing Aria's API endpoints (optional on localhost)
ARIA_API_KEY=

# Rate limiting: max requests per window (default: 60)
RATE_LIMIT_MAX=60

# Rate limiting: window duration in ms (default: 60000)
RATE_LIMIT_WINDOW_MS=60000

# Static export mode (set to "1" for GitHub Pages static build)
NEXT_PUBLIC_STATIC=0

# Base path for static export (e.g., "/aria" for GitHub Pages)
NEXT_PUBLIC_BASE_PATH=

# Default backend URL for Ollama (used in Settings UI)
# NEXT_PUBLIC_OLLAMA_URL=http://localhost:11434
